class Solution {
    public int countSubarrays(int[] nums, int k){
        int l=0,r=0,c=0,s=0;
        while(r<nums.length){
            s+=(nums[r]%2);
            while(s>k){
                s-=(nums[l]%2);
                l++;
            }
            c+=(r-l+1);
            r++;
        }
        return c;
    }
    public int numberOfSubarrays(int[] nums, int k) {
        return countSubarrays(nums,k)-countSubarrays(nums,k-1);
    }
}
