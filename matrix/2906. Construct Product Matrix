class Solution {
    public int[][] constructProductMatrix(int[][] grid) {
        int mod=12345;
        int m=grid.length,n=grid[0].length;
        int[][] p=new int[m][n];
        long suff=1;
        for(int i=m-1;i>=0;i--){
            for(int j=n-1;j>=0;j--){
                p[i][j]=(int)suff;
                suff=(suff*grid[i][j])%mod;
            }
        }
        long pref=1;
        for(int i=0;i<m;i++){
            for(int j=0;j<n;j++){
                p[i][j]=(int)((pref*p[i][j])%mod);
                pref=(pref*grid[i][j])%mod;
            }
        }
        return p;
    }
}
