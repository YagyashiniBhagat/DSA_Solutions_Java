class Solution {
    public boolean areSimilar(int[][] mat, int k) {
        int m=mat.length,n=mat[0].length;
        k=k%n;
        if(k==0) return true;
        for(int i=0;i<m;i++){
            for(int j=0;j<n;j++){
                int currind=j,finalind;
                if(i%2==0) finalind=(j+k)%n;
                else finalind=(j-k+n)%n;
                if(mat[i][currind]!=mat[i][finalind]) return false;
            }
        }
        return true;
    }
}
