class Solution {
    public boolean dfs(int[][] grid,int i,int j,boolean[][] visited,Map<Integer, int[][]> directions,int m,int n){
        if(i==m-1 && j==n-1) return true;
        visited[i][j]=true;
        for(int[] dir:directions.get(grid[i][j])){
            int newi=i+dir[0],newj=j+dir[1];
            if(newi<0 || newi>=m || newj<0 || newj>=n || visited[newi][newj]) continue;

            //checking if we can come back
            for(int[] backdir : directions.get(grid[newi][newj])){
                if(newi+backdir[0]==i && newj+backdir[1]==j){
                    if(dfs(grid,newi,newj,visited,directions,m,n)) return true;
                }
            }
        }
        return false;
    }

    public boolean hasValidPath(int[][] grid) {
        Map<Integer, int[][]> directions=new HashMap<>();
        directions.put(1,new int[][]{{0,-1},{0,1}});
        directions.put(2,new int[][]{{-1,0},{1,0}});
        directions.put(3,new int[][]{{0,-1},{1,0}});
        directions.put(4,new int[][]{{0,1},{1,0}});
        directions.put(5,new int[][]{{0,-1},{-1,0}});
        directions.put(6,new int[][]{{-1,0},{0,1}});
        int m=grid.length;
        int n=grid[0].length;
        boolean[][] visited=new boolean[m][n];
        return dfs(grid,0,0,visited,directions,m,n);
    }
}
