class Solution {
    int mod=(int)1e9 + 7;
    public int xorAfterQueries(int[] nums, int[][] queries) {
        for(int[] q:queries){
            int l=q[0],r=q[1],k=q[2],v=q[3];
            while(l<=r){
                nums[l]=(int)((1L*nums[l]*v) % mod);
                l+=k;
            }
        }
        int xor=0;
        for(int num:nums){
            xor^=num;   
        }
        return xor;
    }
}
