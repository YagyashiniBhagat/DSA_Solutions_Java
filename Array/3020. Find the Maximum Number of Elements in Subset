class Solution {
    public int maximumLength(int[] nums) {
        HashMap<Integer,Integer> map=new HashMap<>();
        for(int num:nums){
            map.put(num,map.getOrDefault(num,0)+1);
        }
        int maxlen=0;
        int ones=map.getOrDefault(1,0);
        maxlen=(ones%2==1) ? ones : ones-1;
        for(int k:map.keySet()){
            if(k==1) continue;
            int len=0,curr=k;
            while(map.getOrDefault(curr,0)>1){
                curr*=curr;
                len+=2;
            }
            if(map.containsKey(curr)) len+=1;
            else len-=1;
            maxlen=Math.max(maxlen,len);
        }
        return maxlen;
    }
}
