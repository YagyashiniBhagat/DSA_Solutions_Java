    public long get1D(int side,int x,int y){
        if(y==0) return x;
        else if(x==side) return side+y;
        else if(y==side) return 3l*side - x;
        else return 4l*side - y;
    }
    public int lowerbound(long[] arr,int left,int right,long target){
        int ans=right;
        while(left<right){
            int m=left+(right-left)/2;
            if(arr[m]>=target){
                ans=m;
                right=m;
            }
            else left=m+1;
        }
        return ans;
    }
    public boolean check(long[] doubled,int n,int k,int side,int mid){
        long perim=4l*side;
        for(int i=0;i<n;i++){
            int cnt=1,idx=i;
            long lastpos=doubled[idx];
            for(int j=2;j<=k;j++){
                long target=lastpos+mid;
                int nxtidx=lowerbound(doubled,idx+1,i+n,target);
                if(nxtidx == i+n) break;
                idx=nxtidx;
                lastpos=doubled[idx];
                cnt++;
            }
            if(cnt==k && (doubled[i]+perim-lastpos >= mid)) return true;
        }
        return false;
    }
    public int maxDistance(int side, int[][] points, int k){
        int n=points.length;
        long peri=4l*side;
        long[] positions=new long[n];
        for(int i=0;i<n;i++){
            positions[i]=get1D(side,points[i][0],points[i][1]);
        }
        Arrays.sort(positions);
        long[] doubled=new long[2*n];
        for(int i=0;i<n;i++){
            doubled[i]=positions[i];
            doubled[i+n]=positions[i]+peri;
        }
        int l=0,r=2*side;
        int res=0;
        while(l<=r){
            int mid=l+(r-l) / 2;
            if(check(doubled,n,k,side,mid)){
                res=mid;
                l=mid+1;
            }
            else r=mid-1;
        }
        return res;
    }
}
