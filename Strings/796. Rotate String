class Solution {
    public void reverse(char[] arr,int start,int end){
        while(start<end){
            char temp=arr[start];
            arr[start]=arr[end];
            arr[end]=temp;
            start++;
            end--;
        }
    }
    public String rotate(char[] arr,int k){
        int n=arr.length;
        if(n==0) return new String(arr);
        k=k%n;
        if(k==0) return new String(arr);
        reverse(arr,0,n-k-1);
        reverse(arr,n-k,n-1);
        reverse(arr,0,n-1);
        return new String(arr);
    }
    public boolean rotateString(String s, String goal) {
        int n=s.length();
        if(n!=goal.length()) return false;
        if(s.equals(goal)) return true;
        char[] original=s.toCharArray();
        for(int i=1;i<n;i++){
            char[] arr=Arrays.copyOf(original,n);
            String ans=rotate(arr,i);
            if(ans.equals(goal)) return true;
        }
        return false;
    }
}
