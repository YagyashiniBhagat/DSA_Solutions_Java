class Solution {
    public int numberOfSubstrings(String s) {
        int count=0;
        int[] mp=new int[3];
        int i=0,j=0;
        int n=s.length();
        while(j<n){
            char ch=s.charAt(j);
            mp[ch-'a']++;

            while(mp[0]>0 && mp[1]>0 && mp[2]>0){
                count+=(n-j);
                mp[s.charAt(i)-'a']--;
                i++;
            }
            j++;
        }
        return count;
    }
}
