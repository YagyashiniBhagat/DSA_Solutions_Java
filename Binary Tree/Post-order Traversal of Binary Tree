using 2 stacks

class Solution {
    public ArrayList<Integer> postOrder(Node root) {
        // code here
        ArrayList<Integer> res=new ArrayList<>();
        Stack<Node> st1=new Stack<>();
        Stack<Node> st2=new Stack<>();
        st1.push(root);
        while(!st1.isEmpty()){
            root=st1.pop();
            st2.push(root);
            if(root.left!=null) st1.push(root.left);
            if(root.right!=null) st1.push(root.right);
        }
        while(!st2.isEmpty()){
            res.add(st2.pop().data);
        }
        return res;
    }
}

using 1 stack

class Solution {
    public ArrayList<Integer> postOrder(Node root) {
        // code here
        ArrayList<Integer> res=new ArrayList<>();
        
        Stack<Node> st=new Stack<>();
        Node curr=root,temp;
        while(curr!=null || !st.isEmpty()){
            if(curr!=null){
                st.push(curr);
                curr=curr.left;
            }else{
                Node node=st.peek();
                temp=node.right;
                if(temp==null){//if no right subtree
                    st.pop();
                    res.add(node.data);//then add the root
                    while(!st.isEmpty() && st.peek().right==node){//and keep popping parents whose right child was this node
                        node=st.pop();
                        res.add(node.data);
                    }
                }
                else curr=temp;//if there is a right subtree go and explore the right subtree first
            }
        }
        return res;
    }
}
