public List<Integer> inorderTraversal(TreeNode root) {
        //inorder: Left->Root->Right
        List<Integer> res=new ArrayList<>();

        if(root==null) return res;
        Stack<TreeNode> st=new Stack<>();
        TreeNode node=root;
        while(true){
            if(node!=null){
                st.push(node);
                node=node.left;
            }
            else{
                if(st.isEmpty()) break;
                node=st.pop();
                res.add(node.val);
                node=node.right;
            }
        }
        return res;
    }
}
