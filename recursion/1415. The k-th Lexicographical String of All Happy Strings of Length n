class Solution {
    void generate(int n, int k, StringBuilder curr,int[] c,String[] res){
        if(curr.length()==n){
            c[0]++;
            if(c[0]==k){
                res[0]=curr.toString();
            }
            return;
        }
        for(char ch='a';ch<='c';ch++){
            if(curr.length()>0 && curr.charAt(curr.length()-1)==ch)
                continue;
            curr.append(ch);
            generate(n,k,curr,c,res);
            curr.deleteCharAt(curr.length()-1);
        }
    }
    public String getHappyString(int n, int k) {
        String[] res={""};
        int[] c={0};
        generate(n,k,new StringBuilder(),c,res);
        return res[0];
    }
}
