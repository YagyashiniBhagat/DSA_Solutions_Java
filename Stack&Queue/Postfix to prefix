class Solution {
    static String postToPre(String str) {
        // code here
        Stack<String> st=new Stack<>();
        int i=0;
        while(i<str.length()){
            char ch=str.charAt(i);
            if(Character.isLetterOrDigit(ch)) st.push(String.valueOf(ch));
            else{
                String t1=st.pop();
                String t2=st.pop();
                st.push(ch+t2+t1);
            }
            i++;
        }
        return st.peek();
    }
}
