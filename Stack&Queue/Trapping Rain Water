class Solution {
    public int trap(int[] arr) {
        int n=arr.length;
        int tot=0,lmax=0,rmax=0,l=0,r=n-1;
        while(l<r){
            if(arr[l]<=arr[r]){
                if(lmax>arr[l])
                    tot+=lmax-arr[l];
                else lmax=arr[l];
                l++;
            }else{
                if(rmax>arr[r]) tot+=rmax-arr[r];
                else rmax=arr[r];
                r--;
            }
        }
        return tot;
    }
}
