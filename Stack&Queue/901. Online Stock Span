class StockSpanner {

    Stack<int[]> st;
    int ind;
    public StockSpanner() {
        st=new Stack<>();
        ind=0;
    }
    
    public int next(int price) {
        while(!st.isEmpty() && st.peek()[0] <= price)
            st.pop();
        int span=ind-(st.isEmpty() ? -1 : st.peek()[1]);
        st.push(new int[]{price,ind});
        ind++;
        return span;
    }
}

