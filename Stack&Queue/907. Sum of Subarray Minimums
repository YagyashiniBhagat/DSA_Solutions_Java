class Solution {
    int[] nextsmallestelement(int[] arr){
        Stack<Integer> st=new Stack<>();
        int n=arr.length;
        int[] ans=new int[n];
        for(int i=n-1;i>=0;i--){
            while(!st.isEmpty() && arr[st.peek()] >= arr[i]) st.pop();
            ans[i]=(st.isEmpty()) ? n : st.peek();
            st.push(i);
        }
        return ans;
    }
    int[] previoussmallestorequalelement(int[] arr){
        Stack<Integer> st=new Stack<>();
        int n=arr.length;
        int[] ans=new int[n];
        for(int i=0;i<n;i++){
            while(!st.isEmpty() && arr[st.peek()] > arr[i]) st.pop();
            ans[i]=(st.isEmpty()) ? -1 : st.peek();
            st.push(i);
        }
        return ans;
    }
    public int sumSubarrayMins(int[] arr) {
        int[] nse=nextsmallestelement(arr);
        int[] psee=previoussmallestorequalelement(arr);
        int n=arr.length;
        long tot=0;
        int mod=(int)1e9+7;
        for(int i=0;i<n;i++){
            int left=i-psee[i];
            int right=nse[i]-i;
            long freq=left*right*1L;
            tot=(tot+((freq*arr[i]) % mod))%mod;
        }
        return (int)tot;
    }
}
