
class Solution {
    public static int[] count_NGE(int arr[], int indices[]) {
        // code here
        int q=indices.length;
        int[] ans=new int[q];
        for(int i=0;i<q;i++){
            int x=arr[indices[i]],c=0;
            for(int j=indices[i]+1;j<arr.length;j++){
                if(arr[j]>x) c++;
            }
            ans[i]=c;
        }
        return ans;
    }
}
