class Solution {
    public int candy(int[] ratings) {
        //brute force TC-O(3n) SC-O(n)
        int n=ratings.length;
        int[] left=new int[n];
        left[0]=1;
        for(int i=1;i<n;i++){
            if(ratings[i-1]<ratings[i]) left[i]=left[i-1]+1;
            else left[i]=1;
        }
        for(int i=n-2;i>=0;i--){
            if(ratings[i+1]<ratings[i]){
                left[i]=Math.max(left[i],left[i+1]+1);
            }
        }
        int s=0;
        for(int i=0;i<n;i++){
            s+=left[i];
        }
        return s;
    }
}
