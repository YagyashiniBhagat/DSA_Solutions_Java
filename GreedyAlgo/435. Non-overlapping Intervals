class Solution {
    public int eraseOverlapIntervals(int[][] intervals) {
        Arrays.sort(intervals, (a,b)->a[1]-b[1]);
        int lastendtime=intervals[0][1],c=0;
        int n=intervals.length;
        for(int i=1;i<n;i++){
            if(intervals[i][0]<lastendtime) c++;
            else
                lastendtime=intervals[i][1];
        }
        return c;
    }
}
