    public boolean checkValidString(String s) {
        // return isvalid(s,0,0);
        //brute force recursion tc:O(3^n)


        //optimal
        int min=0,max=0;
        for(char ch:s.toCharArray()){
            if(ch=='('){
                min++; max++;
            }
            else if(ch==')'){
                min--;
                max--;
            }else{
                min--;
                max++;
            }
            if(min<0) min=0;
            if(max<0) return false;
        }
        return (min==0);

    }
