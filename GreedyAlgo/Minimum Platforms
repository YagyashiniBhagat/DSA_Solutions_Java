class Solution {
    public int minPlatform(int arr[], int dep[]) {
        //  code here
        Arrays.sort(arr);
        Arrays.sort(dep);
        int i=0,j=0,c=0,maxc=0;
        while(i<arr.length){
            if(arr[i]<=dep[j]){
                c++;
                i++;
            }
            else{
                c--;
                j++;
            }
            maxc=Math.max(maxc,c);
        }
        return maxc;
    }
}
